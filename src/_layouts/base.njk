<!DOCTYPE html>
<html lang="{{ lang | default('ro') }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }} | CONSARHOUSE</title>
    <meta name="description" content="{{ description | default('CONSARHOUSE — Arhitectură și Construcții de Substanță') }}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        :root {
            --bg: #3D454D;
            --surface: #454D55;
            --accent: #E9E4DF;
            --text-dim: rgba(233, 228, 223, 0.5);
            --border: rgba(233, 228, 223, 0.1);
            --font-serif: 'Playfair Display', serif;
            --font-sans: 'Inter', sans-serif;
            --transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        html { scroll-behavior: smooth; }

        body {
            background-color: var(--bg);
            color: var(--accent);
            font-family: var(--font-sans);
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
            cursor: crosshair;
        }

        .noise-overlay {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            pointer-events: none;
            z-index: 999;
            opacity: 0.04;
            background: url('/images/noise.png');
        }

        #cursor-follower {
            position: fixed;
            width: 40px; height: 40px;
            border: 1px solid var(--accent);
            border-radius: 50%;
            pointer-events: none;
            z-index: 9999;
            transform: translate(-50%, -50%);
            transition: width 0.3s, height 0.3s, background 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        #cursor-follower::after {
            content: '';
            width: 4px; height: 4px;
            background: var(--accent);
            border-radius: 50%;
        }

        nav {
            position: fixed;
            top: 0;
            width: 100%;
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 2rem 3rem;
            z-index: 100;
            mix-blend-mode: difference;
        }
        .logo {
            font-family: var(--font-serif);
            font-size: 1.5rem;
            font-weight: 700;
            letter-spacing: -0.02em;
        }
        .nav-links {
            display: flex;
            gap: 3rem;
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.2em;
            font-weight: 600;
        }
        .nav-links a {
            color: var(--accent);
            text-decoration: none;
            opacity: 0.6;
            transition: var(--transition);
        }
        .nav-links a:hover, .nav-links a.active { opacity: 1; }

        .section-label {
            font-size: 0.55rem;
            text-transform: uppercase;
            letter-spacing: 0.25em;
            color: var(--text-dim);
            display: block;
            margin-bottom: 1.5rem;
        }
        .section-title {
            font-family: var(--font-serif);
            font-size: clamp(2.2rem, 4vw, 3.5rem);
            font-weight: 400;
            line-height: 1.15;
            margin-bottom: 1rem;
        }
        .section-sub {
            color: var(--text-dim);
            font-size: 0.95rem;
            line-height: 1.7;
            max-width: 640px;
        }
        .section-divider {
            border: none;
            border-top: 1px solid var(--border);
            margin: 6rem 0;
        }

        .container { max-width: 1200px; margin: 0 auto; padding: 8rem 3rem 4rem; }

        @media (max-width: 768px) {
            .nav-links { display: none; }
            nav { padding: 1.5rem; }
            .container { padding: 6rem 1.5rem 3rem; }
            .section-divider { margin: 4rem 0; }
        }

        .nav-dropdown-trigger {
            background: none;
            border: none;
            color: var(--accent);
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.2em;
            font-weight: 600;
            cursor: pointer;
            opacity: 0.6;
            transition: var(--transition);
            font-family: var(--font-sans);
            display: inline-flex;
            align-items: center;
            gap: 0.3rem;
        }
        .nav-dropdown-trigger:hover,
        .nav-dropdown-trigger.open { opacity: 1; }
        .nav-chevron {
            display: inline-block;
            transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
            font-size: 0.55rem;
        }
        .nav-dropdown-trigger.open .nav-chevron {
            transform: rotate(180deg);
        }

        .nav-dropdown-backdrop {
            position: fixed;
            top: 0; left: 0;
            width: 100%; height: 100%;
            background: rgba(0,0,0,0.6);
            backdrop-filter: blur(40px);
            -webkit-backdrop-filter: blur(40px);
            z-index: 98;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.25s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .nav-dropdown-backdrop.open { opacity: 1; pointer-events: auto; }

        .nav-dropdown {
            position: fixed;
            top: 5rem;
            left: 0;
            width: 100%;
            z-index: 99;
            opacity: 0;
            pointer-events: none;
            transform: translateY(-15px);
            transition: all 0.35s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .nav-dropdown.open {
            opacity: 1;
            pointer-events: auto;
            transform: translateY(0);
        }
        .nav-dropdown-inner {
            max-width: 1200px;
            margin: 0 auto;
            padding: 2.5rem 3rem;
            max-height: 550px;
            overflow-y: auto;
        }
        .nav-dropdown-inner::-webkit-scrollbar { width: 4px; }
        .nav-dropdown-inner::-webkit-scrollbar-track { background: transparent; }
        .nav-dropdown-inner::-webkit-scrollbar-thumb { background: rgba(233,228,223,0.2); border-radius: 2px; }
        .nav-dropdown-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 2rem;
        }
        .nav-dropdown-card {
            text-decoration: none;
            color: var(--accent);
            transition: var(--transition);
        }
        .nav-dropdown-card:hover .nav-dropdown-img img {
            filter: grayscale(40%) contrast(1) brightness(0.7);
            transform: scale(1.04);
        }
        .nav-dropdown-img {
            aspect-ratio: 4/3;
            overflow: hidden;
            margin-bottom: 1rem;
        }
        .nav-dropdown-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            filter: grayscale(100%) contrast(1.1) brightness(0.5);
            transition: filter 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
        }
        .nav-dropdown-card h4 {
            font-family: var(--font-serif);
            font-size: 1.3rem;
            font-weight: 400;
            margin-bottom: 0.4rem;
        }
        .nav-dropdown-card p {
            font-size: 0.75rem;
            color: var(--text-dim);
            line-height: 1.6;
        }

        @media (max-width: 768px) {
            .nav-dropdown-grid {
                grid-template-columns: repeat(2, 1fr);
                gap: 1rem;
            }
            .nav-dropdown-card h4 { font-size: 1rem; }
            .nav-dropdown-card p { font-size: 0.7rem; }
            .nav-dropdown-inner { padding: 1.5rem; max-height: 70vh; }
            .nav-dropdown { top: 4rem; }
            .nav-dropdown-img { aspect-ratio: 3/2; margin-bottom: 0.6rem; }
        }

    /* pagină-specific */
    </style>
</head>
<body>
    <div class="noise-overlay"></div>
    <div id="cursor-follower"></div>

    <nav>
        <a href="/" class="logo" style="color: var(--accent); text-decoration: none;">CONSARHOUSE</a>
        <div class="nav-links">
            <a href="/" {% if nav_active == 'home' %}class="active"{% endif %}>Acasă</a>
            <button class="nav-dropdown-trigger" onclick="toggleDropdown()" aria-expanded="false">Servicii <span class="nav-chevron">▾</span></button>
            <a href="/proiecte/" {% if nav_active == 'projects' %}class="active"{% endif %}>Portofoliu</a>
            <a href="/blog/" {% if nav_active == 'blog' %}class="active"{% endif %}>Blog</a>
            <a href="/contact/" {% if nav_active == 'contact' %}class="active"{% endif %}>Contacte</a>
        </div>
        <div style="font-size: 0.6rem;">
            {% if lang == 'en' %}
            <a href="/" style="color: var(--accent); text-decoration: none; opacity: 0.5;">RO</a>
            <span style="opacity: 0.3;"> / </span>
            <span style="opacity: 1;">EN</span>
            {% else %}
            <span style="opacity: 1;">RO</span>
            <span style="opacity: 0.3;"> / </span>
            <a href="/en/" style="color: var(--accent); text-decoration: none; opacity: 0.5;">EN</a>
            {% endif %}
        </div>
    </nav>

    <div class="nav-dropdown-backdrop" onclick="closeDropdown()"></div>
    <div class="nav-dropdown" id="nav-dropdown">
        <div class="nav-dropdown-inner">
            <div class="nav-dropdown-grid">
                <a href="/arhitectura/" class="nav-dropdown-card" onclick="closeDropdown()">
                    <div class="nav-dropdown-img">
                        <img src="/images/01.jpg" alt="Planifică" loading="lazy">
                    </div>
                    <h4>Planifică</h4>
                    <p>Consultanță, studiu de fezabilitate, analiză teren, stabilire temă de proiectare.</p>
                </a>
                <a href="/arhitectura/" class="nav-dropdown-card" onclick="closeDropdown()">
                    <div class="nav-dropdown-img">
                        <img src="/images/02.jpg" alt="Arhitectură" loading="lazy">
                    </div>
                    <h4>Arhitectură</h4>
                    <p>Concepte arhitecturale, modificări structurale, extinderi, mansardări.</p>
                </a>
                <a href="/arhitectura/" class="nav-dropdown-card" onclick="closeDropdown()">
                    <div class="nav-dropdown-img">
                        <img src="/images/03.jpg" alt="Construcții" loading="lazy">
                    </div>
                    <h4>Construcții</h4>
                    <p>Consolidare fundații, dezvoltare complexă, structuri de rezistență.</p>
                </a>
                <a href="/arhitectura/" class="nav-dropdown-card" onclick="closeDropdown()">
                    <div class="nav-dropdown-img">
                        <img src="/images/04.jpg" alt="Renovări" loading="lazy">
                    </div>
                    <h4>Renovări</h4>
                    <p>Renovare fațade, restaurare acoperișuri, conservare patrimoniu.</p>
                </a>
                <a href="/arhitectura/" class="nav-dropdown-card" onclick="closeDropdown()">
                    <div class="nav-dropdown-img">
                        <img src="/images/05.jpg" alt="Reparații" loading="lazy">
                    </div>
                    <h4>Reparații</h4>
                    <p>Reparații interioare, lucrări sanitare, mentenanță tehnică.</p>
                </a>
                <a href="/arhitectura/" class="nav-dropdown-card" onclick="closeDropdown()">
                    <div class="nav-dropdown-img">
                        <img src="/images/portfolio-01.jpg" alt="Vizualizări" loading="lazy">
                    </div>
                    <h4>Vizualizări</h4>
                    <p>Randări 3D, design peisagistic, animații imobiliare, marketing.</p>
                </a>
            </div>
        </div>
    </div>

    <main>
        {{ content | safe }}
    </main>

    {% block after_main %}{% endblock %}

    <script>
        function toggleDropdown() {
            var trigger = document.querySelector('.nav-dropdown-trigger');
            var dropdown = document.getElementById('nav-dropdown');
            var backdrop = document.querySelector('.nav-dropdown-backdrop');
            var isOpen = dropdown.classList.contains('open');
            if (isOpen) { closeDropdown(); return; }
            dropdown.classList.add('open');
            backdrop.classList.add('open');
            trigger.classList.add('open');
            trigger.setAttribute('aria-expanded', 'true');
        }
        function closeDropdown() {
            var trigger = document.querySelector('.nav-dropdown-trigger');
            var dropdown = document.getElementById('nav-dropdown');
            var backdrop = document.querySelector('.nav-dropdown-backdrop');
            dropdown.classList.remove('open');
            backdrop.classList.remove('open');
            trigger.classList.remove('open');
            trigger.setAttribute('aria-expanded', 'false');
        }
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape') closeDropdown();
        });

        if (window.location.hash && window.location.hash.indexOf('invite_token') !== -1) {
            window.location.replace('/admin/' + window.location.hash);
        }

        var cursor = document.getElementById('cursor-follower');
        document.addEventListener('mousemove', function(e) {
            cursor.style.left = e.clientX + 'px';
            cursor.style.top = e.clientY + 'px';
        });

        var hoverSelectors = '.service-card, .gallery-item, .sust-card, .tab-btn, .tab-panel, .btn-primary, .btn-secondary, .tech-card, .portfolio-item, .pillar, .blog-card, .slideshow-controls, .slideshow-dot, .nav-dropdown-trigger, .nav-dropdown-card';
        document.querySelectorAll(hoverSelectors).forEach(function(el) {
            el.addEventListener('mouseenter', function() {
                cursor.style.width = '80px';
                cursor.style.height = '80px';
                cursor.style.background = 'rgba(233, 228, 223, 0.08)';
                cursor.innerHTML = '<span style="font-size: 10px; font-weight: 800; color: #E9E4DF;">VIEW</span>';
            });
            el.addEventListener('mouseleave', function() {
                cursor.style.width = '40px';
                cursor.style.height = '40px';
                cursor.style.background = 'transparent';
                cursor.innerHTML = '';
            });
        });

        var observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
                if (entry.isIntersecting) {
                    entry.target.style.opacity = '1';
                    entry.target.style.transform = 'translateY(0)';
                }
            });
        }, { threshold: 0.1 });

        document.querySelectorAll('.sust-card, .gallery-item, .portfolio-item, .pillar, .blog-card').forEach(function(el) {
            el.style.opacity = '0';
            el.style.transform = 'translateY(30px)';
            el.style.transition = 'all 1s cubic-bezier(0.16, 1, 0.3, 1)';
            observer.observe(el);
        });
    </script>
</body>
</html>
