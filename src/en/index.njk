<style>
.hero-matrix {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    grid-template-rows: auto auto;
    min-height: 100vh;
    padding-top: 6rem;
    border-bottom: 1px solid var(--border);
}
.matrix-cell {
    position: relative;
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 2.5rem;
    transition: var(--transition);
}
.matrix-cell:nth-child(3), .matrix-cell:nth-child(6) { border-right: none; }
.title-cell { padding: 4rem 3rem; justify-content: center; min-height: 450px; }
.title-cell h1 {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1.05;
    font-weight: 400;
    margin-bottom: 2rem;
}
.title-cell .metadata {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--text-dim);
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
}
.service-card { min-height: 450px; }
.service-card .bg-img {
    position: absolute; top: 0; left: 0;
    width: 100%; height: 100%;
    background-size: cover;
    background-position: center;
    filter: grayscale(100%) contrast(1.1) brightness(0.5);
    transition: var(--transition);
    z-index: 1;
}
.service-card:hover .bg-img {
    filter: grayscale(100%) contrast(1.2) brightness(0.7);
    transform: scale(1.05);
}
.service-card .content { position: relative; z-index: 2; }
.card-num {
    position: absolute;
    top: 2.5rem; left: 2.5rem;
    font-size: 0.7rem;
    font-family: var(--font-sans);
    opacity: 0.4;
    z-index: 2;
}
.service-card h2 {
    font-family: var(--font-serif);
    font-size: 2.5rem;
    margin-bottom: 1rem;
    font-weight: 400;
}
.sub-services {
    font-size: 0.75rem;
    line-height: 1.6;
    color: var(--text-dim);
    max-width: 280px;
    height: 0;
    overflow: hidden;
    transition: var(--transition);
    opacity: 0;
}
.service-card:hover .sub-services { height: 80px; opacity: 1; margin-top: 1rem; }
.bottom-shelf {
    display: grid;
    grid-template-columns: 2fr 1fr;
    border-bottom: 1px solid var(--border);
}
.shelf-cell { padding: 4rem 3rem; border-right: 1px solid var(--border); }
.shelf-cell:last-child { border-right: none; }
.blog-preview { display: flex; gap: 2rem; align-items: center; }
.blog-dot { width: 8px; height: 8px; background: var(--accent); border-radius: 50%; }
.view-btn {
    background: var(--accent);
    color: var(--bg);
    border: none;
    padding: 1rem 2rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: 2rem;
    cursor: pointer;
    transition: var(--transition);
}
.view-btn:hover {
    background: transparent;
    color: var(--accent);
    outline: 1px solid var(--accent);
}
@media (max-width: 1024px) { .hero-matrix { grid-template-columns: 1fr 1fr; } }
@media (max-width: 768px) { .hero-matrix { grid-template-columns: 1fr; } }
</style>

