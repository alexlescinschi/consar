---
layout: base.njk
title: Proiecte
nav_active: projects
---

<style>
.portfolio-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.5rem;
    margin-top: 2rem;
}
.portfolio-item {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4/3;
}
.portfolio-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%) contrast(1.1) brightness(0.35);
    transition: filter 1.2s cubic-bezier(0.16, 1, 0.3, 1), transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
}
.portfolio-item:hover img {
    filter: grayscale(60%) contrast(1) brightness(0.65);
    transform: scale(1.03);
}
.portfolio-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1.5rem;
    z-index: 2;
}
.portfolio-overlay h4 {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 400;
    margin-bottom: 0.3rem;
}
.portfolio-overlay span {
    font-size: 0.7rem;
    color: var(--text-dim);
}
.portfolio-overlay a {
    color: var(--accent);
    text-decoration: none;
}

@media (max-width: 1024px) {
    .portfolio-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 768px) {
    .portfolio-grid { grid-template-columns: 1fr; }
}
</style>

<div class="container">
    <span class="section-label">Portofoliu</span>
    <h1 class="section-title">Proiecte<br>Realizate</h1>
    <p class="section-sub">O selecție de proiecte care ilustrează diversitatea și calitatea serviciilor noastre de arhitectură.</p>

    <div class="portfolio-grid">
        {% set projects = collections.projects_ro | reverse %}
        {% for proj in projects %}
        <div class="portfolio-item">
            {% set first_block = proj.data.blocks[0] %}
            <a href="{{ proj.url }}">
                <img src="{{ first_block.image }}" alt="{{ proj.data.title }}" loading="lazy">
                <div class="portfolio-overlay">
                    <h4>{{ proj.data.title }}</h4>
                    {% for field in first_block.tech_fields %}
                    {% if field.label == 'Locație' %}
                    <span>{{ field.value }}, {{ first_block.tech_fields[2].value }}</span>
                    {% endif %}
                    {% endfor %}
                </div>
            </a>
        </div>
        {% else %}
        <p style="color: var(--text-dim);">Niciun proiect publicat încă.</p>
        {% endfor %}
    </div>
</div>
