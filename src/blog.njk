---
layout: base.njk
title: Blog
nav_active: blog
---

<style>
.blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 2rem;
}
.blog-card {
    border: 1px solid var(--border);
    overflow: hidden;
    transition: var(--transition);
}
.blog-card:hover { border-color: rgba(233, 228, 223, 0.2); }
.blog-card img {
    width: 100%;
    aspect-ratio: 16/10;
    object-fit: cover;
    transition: transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
}
.blog-card:hover img {
    transform: scale(1.03);
}
.blog-card-body {
    padding: 1.5rem;
}
.blog-card-body h3 {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 400;
    margin-bottom: 0.5rem;
    line-height: 1.3;
}
.blog-card-body a {
    color: var(--accent);
    text-decoration: none;
}
.blog-card-body .blog-excerpt {
    font-size: 0.8rem;
    color: var(--text-dim);
    line-height: 1.6;
}

@media (max-width: 1024px) {
    .blog-grid { grid-template-columns: 1fr 1fr; }
}
@media (max-width: 768px) {
    .blog-grid { grid-template-columns: 1fr; }
}
</style>

<div class="container">
    <span class="section-label">Jurnal de Arhitectură</span>
    <h1 class="section-title">Blog</h1>
    <p class="section-sub">Articole despre arhitectură, design, sustenabilitate și tendințe în construcții.</p>

    <div class="blog-grid">
        {% set posts = collections.blog_ro | reverse %}
        {% for post in posts %}
        <div class="blog-card">
            {% if post.data.image %}
            <a href="{{ post.url }}"><img src="{{ post.data.image }}" alt="{{ post.data.title }}" loading="lazy"></a>
            {% endif %}
            <div class="blog-card-body">
                <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
                <p class="blog-excerpt">{{ post.data.description | default(post.templateContent | striptags | truncate(120)) }}</p>
            </div>
        </div>
        {% else %}
        <p style="color: var(--text-dim);">Niciun articol publicat încă.</p>
        {% endfor %}
    </div>
</div>
