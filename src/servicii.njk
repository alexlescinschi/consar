{% block after_main %}
<!-- MODAL -->
<div class="modal-overlay" id="modal-overlay">
    <div class="modal">
        <button class="modal-close" onclick="closeModal()">&times;</button>

        <!-- Step 1 -->
        <div class="modal-step active" data-step="1">
            <span class="step-indicator">Pasul 1 / 4</span>
            <h3>Alege categoria de proiect</h3>
            <p style="font-size: 0.8rem; color: var(--text-dim); margin-bottom: 1.5rem;">Selectează o opțiune principală.</p>
            <div class="radio-group">
                <label class="radio-item"><input type="radio" name="categorie" value="Construcții rezidențiale" onchange="onCatChange(this)"><svg class="radio-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9.5L12 3l9 6.5V20a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9.5z"/><path d="M9 21V12h6v9"/></svg><span>Construcții rezidențiale</span></label>
                <label class="radio-item"><input type="radio" name="categorie" value="Clădiri comerciale" onchange="onCatChange(this)"><svg class="radio-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="18" rx="1"/><path d="M8 21v-4h8v4"/><path d="M12 7v4"/><path d="M8 9h8"/></svg><span>Clădiri comerciale</span></label>
                <label class="radio-item"><input type="radio" name="categorie" value="Clădiri publice și instituționale" onchange="onCatChange(this)"><svg class="radio-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="18" rx="1"/><path d="M6 3v18"/><path d="M2 9h22"/><path d="M12 12h4"/></svg><span>Clădiri publice și instituționale</span></label>
                <label class="radio-item"><input type="radio" name="categorie" value="Construcții industriale" onchange="onCatChange(this)"><svg class="radio-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M2 20h20"/><path d="M5 20V6l7-3v17"/><path d="M19 20V12l-7-3"/><path d="M9 12h4"/><path d="M16 12h3"/></svg><span>Construcții industriale</span></label>
                <label class="radio-item"><input type="radio" name="categorie" value="Turism și agrement" onchange="onCatChange(this)"><svg class="radio-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="5" width="20" height="16" rx="1"/><path d="M6 12h4v4H6z"/><path d="M14 12h4v4h-4z"/><path d="M10 5V2h4v3"/></svg><span>Turism și agrement</span></label>
                <label class="radio-item"><input type="radio" name="categorie" value="Amenajări exterioare și urbanism" onchange="onCatChange(this)"><svg class="radio-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="8" cy="18" r="2"/><circle cx="16" cy="18" r="2"/><path d="M4 18c0-5 3-9 8-9s8 4 8 9"/><path d="M12 9V3"/><path d="M9 3h6"/></svg><span>Amenajări exterioare și urbanism</span></label>
                <label class="radio-item"><input type="radio" name="categorie" value="Reabilitări și restaurări" onchange="onCatChange(this)"><svg class="radio-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94L2 24l4.53-11.53a6 6 0 0 1 7.94-7.94l.77.77"/></svg><span>Reabilitări și restaurări</span></label>
            </div>
            <div class="btn-row">
                <button class="btn-next" onclick="goToStep(2)">Continuă →</button>
            </div>
        </div>

        <!-- Step 2 -->
        <div class="modal-step" data-step="2">
            <span class="step-indicator">Pasul 2 / 4</span>
            <h3>Detalii despre Proiect</h3>

            <div id="step2-residential">
                <div class="sub-section-title">A. Tipul de locuință și dimensiuni</div>
                <div class="sub-details" style="margin-bottom: 1rem;">
                    <label class="checkbox-item"><input type="checkbox" class="house-type" data-type="individuala" onchange="toggleHouseFields()"><img class="checkbox-thumb" src="/images/thumbnails/1.jpg" alt="" loading="lazy"><span>1) Casă individuală</span></label>
                    <div class="sub-details-grid house-fields" data-type="individuala" style="display: none;">
                        <div class="field-group"><label>Lungime (m)</label><input type="number" step="0.1" placeholder="ex: 15"></div>
                        <div class="field-group"><label>Lățime (m)</label><input type="number" step="0.1" placeholder="ex: 10"></div>
                        <div class="field-group"><label>Nr. etaje</label><input type="number" placeholder="ex: 2"></div>
                        <div class="checkbox-bool"><input type="checkbox"> Subsol</div>
                    </div>
                </div>
                <div class="sub-details" style="margin-bottom: 1rem;">
                    <label class="checkbox-item"><input type="checkbox" class="house-type" data-type="duplex" onchange="toggleHouseFields()"><img class="checkbox-thumb" src="/images/thumbnails/2.jpg" alt="" loading="lazy"><span>2) Casă duplex</span></label>
                    <div class="sub-details-grid house-fields" data-type="duplex" style="display: none;">
                        <div class="field-group"><label>Lungime (m)</label><input type="number" step="0.1" placeholder="ex: 18"></div>
                        <div class="field-group"><label>Lățime (m)</label><input type="number" step="0.1" placeholder="ex: 12"></div>
                        <div class="checkbox-bool"><input type="checkbox"> Subsol</div>
                    </div>
                </div>
                <div class="sub-details" style="margin-bottom: 1rem;">
                    <label class="checkbox-item"><input type="checkbox" class="house-type" data-type="townhouse" onchange="toggleHouseFields()"><img class="checkbox-thumb" src="/images/thumbnails/3.jpg" alt="" loading="lazy"><span>3) Casă înșiruită (townhouse)</span></label>
                    <div class="sub-details-grid house-fields" data-type="townhouse" style="display: none;">
                        <div class="field-group"><label>Lungime (m)</label><input type="number" step="0.1" placeholder="ex: 12"></div>
                        <div class="field-group"><label>Lățime (m)</label><input type="number" step="0.1" placeholder="ex: 6"></div>
                        <div class="field-group"><label>Nr. etaje</label><input type="number" placeholder="ex: 2"></div>
                        <div class="checkbox-bool"><input type="checkbox"> Subsol</div>
                    </div>
                </div>

                <div class="sub-section-title">B. Stil, Materiale și Tehnologie</div>
                <div class="checkbox-group">
                    <label class="checkbox-item"><input type="checkbox" name="stil" value="Vilă"><img class="checkbox-thumb" src="/images/thumbnails/4.jpg" alt="" loading="lazy"><span>Vilă</span></label>
                    <label class="checkbox-item"><input type="checkbox" name="stil" value="Bungalow"><img class="checkbox-thumb" src="/images/thumbnails/5.jpg" alt="" loading="lazy"><span>Bungalow</span></label>
                    <label class="checkbox-item"><input type="checkbox" name="stil" value="Cărămidă"><img class="checkbox-thumb" src="/images/thumbnails/6.jpg" alt="" loading="lazy"><span>Casă din cărămidă</span></label>
                    <label class="checkbox-item"><input type="checkbox" name="stil" value="Beton"><img class="checkbox-thumb" src="/images/thumbnails/7.jpg" alt="" loading="lazy"><span>Casă din beton</span></label>
                    <label class="checkbox-item"><input type="checkbox" name="stil" value="Metalică"><img class="checkbox-thumb" src="/images/thumbnails/8.jpg" alt="" loading="lazy"><span>Structură metalică</span></label>
                    <label class="checkbox-item"><input type="checkbox" name="stil" value="Lemn"><img class="checkbox-thumb" src="/images/thumbnails/9.jpg" alt="" loading="lazy"><span>Casă din lemn</span></label>
                    <label class="checkbox-item"><input type="checkbox" name="stil" value="Modulară"><img class="checkbox-thumb" src="/images/thumbnails/10.jpg" alt="" loading="lazy"><span>Modulară / prefabricată</span></label>
                    <label class="checkbox-item"><input type="checkbox" name="stil" value="Modernă"><img class="checkbox-thumb" src="/images/thumbnails/11.jpg" alt="" loading="lazy"><span>Modernă</span></label>
                    <label class="checkbox-item"><input type="checkbox" name="stil" value="Contemporană"><img class="checkbox-thumb" src="/images/thumbnails/12.jpg" alt="" loading="lazy"><span>Contemporană</span></label>
                    <label class="checkbox-item"><input type="checkbox" name="stil" value="Tradițională"><img class="checkbox-thumb" src="/images/thumbnails/13.jpg" alt="" loading="lazy"><span>Tradițională</span></label>
                    <label class="checkbox-item"><input type="checkbox" name="stil" value="Rustic"><img class="checkbox-thumb" src="/images/thumbnails/14.jpg" alt="" loading="lazy"><span>Rustic</span></label>
                    <label class="checkbox-item"><input type="checkbox" name="stil" value="Mediteraneană"><img class="checkbox-thumb" src="/images/thumbnails/15.jpg" alt="" loading="lazy"><span>Mediteraneană</span></label>
                    <label class="checkbox-item"><input type="checkbox" name="stil" value="Scandinavă"><img class="checkbox-thumb" src="/images/thumbnails/16.jpg" alt="" loading="lazy"><span>Scandinavă</span></label>
                    <label class="checkbox-item"><input type="checkbox" name="stil" value="Industrială"><img class="checkbox-thumb" src="/images/thumbnails/17.jpg" alt="" loading="lazy"><span>Industrială</span></label>
                    <label class="checkbox-item"><input type="checkbox" name="stil" value="Pasivă"><img class="checkbox-thumb" src="/images/thumbnails/18.jpg" alt="" loading="lazy"><span>Casă pasivă</span></label>
                    <label class="checkbox-item"><input type="checkbox" name="stil" value="Smart"><img class="checkbox-thumb" src="/images/thumbnails/19.jpg" alt="" loading="lazy"><span>Casă inteligentă</span></label>
                    <label class="checkbox-item"><input type="checkbox" name="stil" value="Ecologică"><img class="checkbox-thumb" src="/images/thumbnails/20.jpg" alt="" loading="lazy"><span>Casă ecologică</span></label>
                    <label class="checkbox-item"><input type="checkbox" name="stil" value="Tiny"><img class="checkbox-thumb" src="/images/thumbnails/21.jpg" alt="" loading="lazy"><span>Tiny house</span></label>
                    <label class="checkbox-item"><input type="checkbox" name="stil" value="Piloni"><img class="checkbox-thumb" src="/images/thumbnails/22.jpg" alt="" loading="lazy"><span>Casă pe piloni</span></label>
                </div>
            </div>

            <div id="step2-generic" style="display: none;">
                <div class="field-group">
                    <label>Descrie proiectul tău</label>
                    <textarea rows="4" name="descriere_proiect" placeholder="Detalii despre proiect: tip clădire, suprafață estimativă, specificații..."></textarea>
                </div>
            </div>

            <div class="btn-row">
                <button class="btn-back" onclick="goToStep(1)">← Înapoi</button>
                <button class="btn-next" onclick="goToStep(3)">Continuă →</button>
            </div>
        </div>

        <!-- Step 3 -->
        <div class="modal-step" data-step="3">
            <span class="step-indicator">Pasul 3 / 4 (Opțional)</span>
            <h3>Servicii de Prezentare / Randări 3D</h3>
            <p style="font-size: 0.8rem; color: var(--text-dim); margin-bottom: 1.5rem;">Bifează livrabilele vizuale de care ai nevoie.</p>
            <div class="checkbox-group">
                <label class="checkbox-item"><input type="checkbox" name="randari" value="Randări Interioare"><span>Randări Interioare</span></label>
                <label class="checkbox-item"><input type="checkbox" name="randari" value="Randări Exterior"><span>Randări Exterior</span></label>
                <label class="checkbox-item"><input type="checkbox" name="randari" value="Interior Design"><span>Randări Interior Design</span></label>
                <label class="checkbox-item"><input type="checkbox" name="randari" value="Peisagistic"><span>Randări Design Peisagistic</span></label>
                <label class="checkbox-item"><input type="checkbox" name="randari" value="Produs Marketing"><span>Randări Produs / Marketing</span></label>
                <label class="checkbox-item"><input type="checkbox" name="randari" value="Animații 3D"><span>Animații 3D Imobiliare</span></label>
            </div>
            <div class="btn-row">
                <button class="btn-back" onclick="goToStep(2)">← Înapoi</button>
                <button class="btn-next" onclick="goToStep(4)">Continuă →</button>
            </div>
        </div>

        <!-- Step 4 -->
        <div class="modal-step" data-step="4">
            <span class="step-indicator">Pasul 4 / 4</span>
            <h3>Date de Contact</h3>
            <p style="font-size: 0.8rem; color: var(--text-dim); margin-bottom: 1.5rem;">Completează datele și trimite solicitarea.</p>
            <div class="contact-row">
                <div class="field-group"><label>Nume și Prenume *</label><input type="text" id="form-nume" required placeholder="Numele tău complet"></div>
                <div class="field-group"><label>Email *</label><input type="email" id="form-email" required placeholder="email@exemplu.ro"></div>
            </div>
            <div class="field-group"><label>Telefon *</label><input type="tel" id="form-telefon" required placeholder="07xx xxx xxx"></div>
            <div class="field-group"><label>Mesaj / Detalii suplimentare</label><textarea rows="4" id="form-mesaj" placeholder="Data estimativă, buget orientativ, alte detalii..."></textarea></div>
            <div class="btn-row">
                <button class="btn-back" onclick="goToStep(3)">← Înapoi</button>
                <button class="btn-next" onclick="submitForm()">Trimite Solicitarea →</button>
            </div>
        </div>
    </div>
</div>
{% endblock %}
