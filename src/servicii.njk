<style>
.container { max-width: 1200px; margin: 0 auto; padding: 8rem 3rem 4rem; }

.section-divider {
    border: none;
    border-top: 1px solid var(--border);
    margin: 5rem 0;
}

.section-label {
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.3em;
    color: var(--text-dim);
    margin-bottom: 1rem;
    display: block;
}

.section-title {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 5vw, 3.5rem);
    line-height: 1.1;
    font-weight: 400;
    margin-bottom: 1rem;
}

.section-sub {
    font-size: 1rem;
    color: var(--text-dim);
    line-height: 1.7;
    max-width: 600px;
    margin-bottom: 2rem;
}

.intro {
    position: relative;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    overflow: hidden;
    padding: 6rem 3rem 5rem;
}
.intro .intro-content {
    position: relative;
    z-index: 3;
    max-width: 800px;
}
.intro h1 {
    font-family: var(--font-serif);
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    line-height: 1.05;
    font-weight: 400;
    margin-bottom: 1.5rem;
}

.pillars {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
}
.pillar {
    padding: 3rem 2rem;
    border-right: 1px solid var(--border);
    position: relative;
    transition: var(--transition);
}
.pillar:last-child { border-right: none; }
.pillar:hover { background: var(--surface); }
.pillar-num {
    font-size: 0.7rem;
    opacity: 0.35;
    margin-bottom: 2rem;
}
.pillar h2 {
    font-family: var(--font-serif);
    font-size: 1.8rem;
    font-weight: 400;
    margin-bottom: 1rem;
    line-height: 1.2;
}
.pillar .pillar-desc {
    font-size: 0.8rem;
    color: var(--text-dim);
    line-height: 1.7;
    margin-bottom: 1.5rem;
}
.pillar ul {
    list-style: none;
    font-size: 0.75rem;
    color: var(--text-dim);
    line-height: 1.8;
}
.pillar ul li::before { content: '— '; opacity: 0.4; }

/* PORTFOLIO GALLERY */
.portfolio-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
}
.portfolio-item {
    position: relative;
    aspect-ratio: 4/3;
    overflow: hidden;
    cursor: pointer;
}
.portfolio-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
}
.portfolio-item:hover img {
    transform: scale(1.08);
}
.portfolio-overlay {
    position: absolute;
    bottom: 0; left: 0; right: 0;
    padding: 2rem;
    background: linear-gradient(transparent, rgba(61, 69, 77, 0.9));
    z-index: 2;
    transform: translateY(20px);
    opacity: 0;
    transition: var(--transition);
}
.portfolio-item:hover .portfolio-overlay {
    transform: translateY(0);
    opacity: 1;
}
.portfolio-overlay h4 {
    font-family: var(--font-serif);
    font-size: 1.3rem;
    margin-bottom: 0.3rem;
}
.portfolio-overlay span {
    font-size: 0.7rem;
    opacity: 0.6;
}

/* VIDEO GRID */
.video-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    border: 1px solid var(--border);
}
.video-card {
    border-right: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    transition: var(--transition);
}
.video-card:nth-child(2n) { border-right: none; }
.video-card:hover { background: var(--surface); }
.video-thumb {
    aspect-ratio: 16/9;
    overflow: hidden;
}
.video-thumb iframe {
    width: 100%;
    height: 100%;
    border: none;
}
.video-info {
    padding: 2rem;
}
.video-info h4 {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    font-weight: 400;
    margin-bottom: 0.5rem;
}
.video-info p {
    font-size: 0.8rem;
    color: var(--text-dim);
    line-height: 1.6;
}

/* STATS */
/* CTA */
.cta-block {
    text-align: left;
    padding: 5rem 3rem;
    border: 1px solid var(--border);
    border-radius: 2px;
    background: var(--surface);
}
.cta-block h2 {
    font-family: var(--font-serif);
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    font-weight: 400;
    margin-bottom: 1rem;
    text-align: left;
}
.cta-block p {
    font-size: 0.9rem;
    color: var(--text-dim);
    margin: 0 0 2rem;
    line-height: 1.7;
}

.cta-block-grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: 3rem;
    align-items: center;
}
.cta-block-gallery {
    min-width: 0;
    overflow: hidden;
}

.cta-block-scroll { overflow: hidden; }
.cta-block-track { display: flex; width: max-content; }
.cta-block-row-left .cta-block-track { animation: cta-block-scroll-left 60s linear infinite; }
.cta-block-row-right .cta-block-track { animation: cta-block-scroll-right 60s linear infinite; }
.cta-block-scroll:hover .cta-block-track { animation-play-state: paused; }
.cta-block-scroll img {
    width: 180px; height: 130px;
    object-fit: cover;
    border-radius: 4px;
    margin-right: 0.5rem;
    flex-shrink: 0;
}
@keyframes cta-block-scroll-left {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
}
@keyframes cta-block-scroll-right {
    0% { transform: translateX(-50%); }
    100% { transform: translateX(0); }
}
.btn-cta {
    background: var(--accent);
    color: var(--bg);
    border: none;
    padding: 1.2rem 2.5rem;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    cursor: pointer;
    transition: var(--transition);
    font-family: var(--font-sans);
}
.btn-cta:hover {
    background: transparent;
    color: var(--accent);
    outline: 1px solid var(--accent);
}

/* MODAL */
.modal-overlay {
    position: fixed;
    top: 0; left: 0;
    width: 100%; height: 100%;
    background: rgba(61, 69, 77, 0.92);
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s;
}
.modal-overlay.active { opacity: 1; pointer-events: all; }
.modal {
    background: var(--surface);
    border: 1px solid var(--border);
    width: 90%;
    max-width: 700px;
    max-height: 85vh;
    overflow-y: auto;
    padding: 3rem;
    position: relative;
}
.modal-close {
    position: absolute;
    top: 1.5rem; right: 1.5rem;
    background: none;
    border: none;
    color: var(--accent);
    font-size: 1.5rem;
    cursor: pointer;
    opacity: 0.5;
    transition: var(--transition);
    line-height: 1;
}
.modal-close:hover { opacity: 1; }
.modal-step { display: none; }
.modal-step.active {
    display: block;
    animation: fadeSlideIn 0.5s cubic-bezier(0.16, 1, 0.3, 1);
}
@keyframes fadeSlideIn {
    from { opacity: 0; transform: translateY(15px); }
    to { opacity: 1; transform: translateY(0); }
}
.modal h3 {
    font-family: var(--font-serif);
    font-size: 1.8rem;
    font-weight: 400;
    margin-bottom: 0.5rem;
}
.modal .step-indicator {
    font-size: 0.6rem;
    text-transform: uppercase;
    letter-spacing: 0.35em;
    color: var(--text-dim);
    margin-bottom: 2rem;
    display: block;
}
.modal .radio-group,
.modal .checkbox-group {
    display: grid;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
}
.modal .radio-group { grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); }
.modal .checkbox-group { grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); }
.modal .radio-item,
.modal .checkbox-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    border: 1px solid var(--border);
    cursor: pointer;
    transition: var(--transition);
    font-size: 0.8rem;
}
.modal .radio-item:hover,
.modal .checkbox-item:hover {
    border-color: rgba(233, 228, 223, 0.3);
    background: rgba(233, 228, 223, 0.03);
}
.modal .radio-item input,
.modal .checkbox-item input {
    appearance: none;
    -webkit-appearance: none;
    width: 14px; height: 14px;
    border: 1px solid var(--text-dim);
    border-radius: 50%;
    flex-shrink: 0;
    cursor: pointer;
    transition: var(--transition);
}
.modal .checkbox-item input { border-radius: 0; }
.modal .radio-item input:checked {
    border-color: var(--accent);
    background: var(--accent);
}
.modal .checkbox-item input:checked {
    border-color: var(--accent);
    background: var(--accent);
}
.modal .checkbox-item input:checked::after {
    content: '';
    position: absolute;
    left: 4px; top: 1px;
    width: 4px; height: 8px;
    border: solid var(--bg);
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
}
.modal .radio-icon {
    opacity: 0.35;
    transition: var(--transition);
    flex-shrink: 0;
}
.modal .radio-item input:checked ~ .radio-icon { opacity: 0.8; }
.modal .radio-item input:checked ~ span,
.modal .checkbox-item input:checked ~ span { color: var(--accent); }
.modal .checkbox-icon {
    opacity: 0.35;
    transition: var(--transition);
    flex-shrink: 0;
}
.modal .checkbox-item input:checked ~ .checkbox-icon { opacity: 0.8; }
.modal .checkbox-thumb {
    width: 40px;
    height: 40px;
    object-fit: cover;
    border-radius: 2px;
    flex-shrink: 0;
    opacity: 0.65;
    transition: var(--transition);
}
.modal .checkbox-item input:checked ~ .checkbox-thumb,
.modal .checkbox-item:hover .checkbox-thumb { opacity: 1; }
.modal .field-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    margin-bottom: 1rem;
}
.modal .field-group label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-dim);
}
.modal .field-group input,
.modal .field-group textarea {
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--accent);
    padding: 0.8rem 1rem;
    font-family: var(--font-sans);
    font-size: 0.8rem;
    transition: var(--transition);
    outline: none;
}
.modal .field-group input:focus,
.modal .field-group textarea:focus { border-color: rgba(233, 228, 223, 0.4); }
.modal .contact-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
}
.modal .btn-row {
    display: flex;
    gap: 1rem;
    margin-top: 2rem;
}
.modal .btn-next,
.modal .btn-back {
    background: var(--accent);
    color: var(--bg);
    border: none;
    padding: 0.9rem 2rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    cursor: pointer;
    transition: var(--transition);
    font-family: var(--font-sans);
}
.modal .btn-back {
    background: transparent;
    color: var(--text-dim);
    border: 1px solid var(--border);
}
.modal .btn-next:hover {
    background: transparent;
    color: var(--accent);
    outline: 1px solid var(--accent);
}
.modal .btn-back:hover {
    color: var(--accent);
    border-color: rgba(233, 228, 223, 0.4);
}
.modal .sub-details {
    margin-top: 1rem;
    padding: 1.5rem;
    border: 1px solid var(--border);
    background: rgba(61, 69, 77, 0.4);
}
.modal .sub-details-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1rem;
    margin-bottom: 1rem;
}
.modal .checkbox-bool {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.8rem;
    margin-top: 0.3rem;
}
.modal .sub-section-title {
    font-family: var(--font-serif);
    font-size: 1rem;
    font-weight: 400;
    margin: 1.5rem 0 1rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
}
.modal .sub-section-title:first-of-type {
    border-top: none;
    padding-top: 0;
    margin-top: 0;
}

.success-msg {
    text-align: center;
    padding: 2rem;
}
.success-msg .check {
    font-size: 3rem;
    margin-bottom: 1rem;
}
.success-msg h2 {
    font-family: var(--font-serif);
    font-size: 2rem;
    margin-bottom: 1rem;
    font-weight: 400;
}

/* SLIDESHOW */
.slideshow {
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    z-index: 1;
}
.slideshow::after {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to right, rgba(61, 69, 77, 0.85) 0%, rgba(61, 69, 77, 0.55) 50%, rgba(61, 69, 77, 0.7) 100%);
    z-index: 2;
    pointer-events: none;
}
.slideshow-track {
    display: flex;
    width: 100%;
    height: 100%;
    transition: transform 1s cubic-bezier(0.16, 1, 0.3, 1);
}
.slideshow-slide {
    min-width: 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
}
.slideshow-slide img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}
.slideshow-controls {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 4;
    background: none;
    border: 1px solid rgba(233,228,223,0.2);
    color: var(--accent);
    width: 48px;
    height: 48px;
    cursor: pointer;
    font-size: 1.1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition);
    opacity: 0;
}
.slideshow:hover .slideshow-controls { opacity: 1; }
.slideshow-controls:hover {
    background: rgba(233,228,223,0.1);
    border-color: rgba(233,228,223,0.45);
}
.slideshow-prev { left: 2rem; }
.slideshow-next { right: 2rem; }
.slideshow-dots {
    position: absolute;
    bottom: 2.5rem;
    right: 3rem;
    z-index: 4;
    display: flex;
    gap: 0.6rem;
    align-items: center;
}
.slideshow-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    border: 1px solid rgba(233,228,223,0.3);
    background: transparent;
    cursor: pointer;
    transition: var(--transition);
    padding: 0;
}
.slideshow-dot.active { background: var(--accent); border-color: var(--accent); }
.slideshow-counter {
    position: absolute;
    bottom: 2.5rem;
    left: 3rem;
    z-index: 4;
    font-size: 0.65rem;
    font-family: var(--font-sans);
    opacity: 0.4;
    letter-spacing: 0.2em;
}

@media (max-width: 1024px) {
    .portfolio-grid { grid-template-columns: 1fr 1fr; }
    .portfolio-item:nth-child(3n) { border-right: 1px solid var(--border); }
    .portfolio-item:nth-child(2n) { border-right: none; }
}

@media (max-width: 768px) {
    .container { padding: 6rem 1.5rem 3rem; }
    .pillars { grid-template-columns: 1fr; }
    .pillar { border-right: none; }
    .portfolio-grid { grid-template-columns: 1fr; }
    .portfolio-item:nth-child(2n) { border-right: 1px solid var(--border); }
    .portfolio-item:last-child { border-right: none; }
    .video-grid { grid-template-columns: 1fr; }
    .modal { padding: 2rem; width: 95%; }
    .modal .contact-row { grid-template-columns: 1fr; }
    .slideshow { aspect-ratio: auto; }
    .slideshow-caption { padding: 1.5rem; }
    .slideshow-caption h4 { font-size: 1.2rem; }
    .slideshow-controls { opacity: 1; width: 36px; height: 36px; }
    .slideshow-prev { left: 1rem; }
    .slideshow-next { right: 1rem; }
    .slideshow-dots { bottom: 1.5rem; right: 1.5rem; }
    .slideshow-counter { bottom: 1.5rem; left: 1.5rem; }
    .intro { min-height: 70vh; padding: 5rem 1.5rem 3rem; }
    .intro h1 { font-size: clamp(2rem, 7vw, 2.8rem); margin-bottom: 1rem; }
    .section-title { font-size: clamp(1.8rem, 5vw, 2.5rem); }
    .section-label { font-size: 0.6rem; }
    .section-sub { font-size: 0.85rem; }
    .pillar { padding: 2.5rem 1.5rem; }
    .pillar h2 { font-size: 1.5rem; }
    .cta-block { padding: 3rem 1.5rem; text-align: center; }
    .cta-block h2 { font-size: clamp(1.5rem, 4vw, 2rem); text-align: center; }
    .cta-block p { text-align: center; max-width: 480px; margin: 0 auto 2rem; }
    .cta-block-grid { grid-template-columns: 1fr; }
    .cta-block-gallery { order: 1; }
    .cta-block-text { order: 2; }
    .cta-block-scroll img { width: 140px; height: 100px; }
    .radio-group, .checkbox-group { grid-template-columns: 1fr; }
    .sub-details-grid { grid-template-columns: 1fr; margin-left: 0; }
}
</style>

