        <div class="stat-item">
            <div class="stat-num" id="counter-clients">0</div>
            <div class="stat-label">Clienți</div>
        </div>
        <div class="stat-item">
            <div class="stat-num" id="counter-years">0</div>
            <div class="stat-label">Ani Experiență</div>
        </div>
